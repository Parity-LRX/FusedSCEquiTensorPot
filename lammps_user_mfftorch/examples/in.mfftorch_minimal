units metal
atom_style atomic
boundary p p p

# read_data system.data
# 或者用 create_atoms 生成一个最小体系

neighbor 1.0 bin

# Kokkos GPU 运行时建议命令行启用：
#   lmp -k on g 1 -sf kk -pk kokkos newton on neigh half -in in.mfftorch_minimal

# cutoff(Angstrom) + device(cpu|cuda)
pair_style mff/torch 5.0 cuda

# pair_coeff * * <core.pt> <elem_for_type1> <elem_for_type2> ...
pair_coeff * * core.pt H O

thermo 10
run 10

